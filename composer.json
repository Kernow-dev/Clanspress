{
	"name": "kernowdev/clanspress",
	"description": "Community management system for gamers and sports teams plugin for Wordpress.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"autoload": {
		"classmap": [
			"clanspress.php",
			"inc/"
		],
		"psr-4": {
			"Kernowdev\\Clanspress\\": "inc/"
		},
		"files": [
			"inc/extensions/notifications/functions.php",
			"inc/extensions/events/functions.php",
			"inc/class-block-patterns.php",
			"inc/functions-wordban.php"
		]
	},
	"authors": [
		{
			"name": "kernowdev",
			"email": "wasson@kernow.dev"
		}
	],
	"minimum-stability": "dev",
	"require-dev": {
		"php-stubs/wordpress-stubs": "^6.8",
		"phpcompatibility/phpcompatibility-wp": "dev-master",
		"phpstan/phpstan": "^2.1",
		"squizlabs/php_codesniffer": "3.x-dev",
		"wp-coding-standards/wpcs": "dev-develop"
	},
	"scripts": {
		"lint:php": "phpcs",
		"lint:php:fix": "phpcbf",
		"phpstan": "phpstan analyse --memory-limit=1024M"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
