{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "clanspress/player-settings-link",
  "version": "0.1.0",
  "title": "Player settings link",
  "category": "clanspress-players",
  "icon": "admin-settings",
  "description": "Link to player account settings. Only shown when the viewer is the profile owner.",
  "textdomain": "clanspress",
  "usesContext": [
    "postId",
    "postType",
    "clanspress/playerId"
  ],
  "attributes": {
    "label": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": true,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "typography": {
      "fontSize": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}