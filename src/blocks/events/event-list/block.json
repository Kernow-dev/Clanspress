{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/event-list",
	"version": "1.0.0",
	"title": "Event list",
	"category": "clanspress",
	"icon": "list-view",
	"description": "List scheduled events for the current team or group context.",
	"textdomain": "clanspress",
	"attributes": {
		"scopeType": {
			"type": "string",
			"default": "team"
		},
		"teamId": {
			"type": "number",
			"default": 0
		},
		"groupId": {
			"type": "number",
			"default": 0
		},
		"limit": {
			"type": "number",
			"default": 20
		}
	},
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false,
		"interactivity": true
	},
	"editorScript": "file:./index.js",
	"viewScriptModule": "file:./view.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanspress-event-list",
		"color": ".wp-block-clanspress-event-list",
		"typography": ".wp-block-clanspress-event-list",
		"border": ".wp-block-clanspress-event-list"
	}
}
