{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/team-challenge-button",
	"version": "1.0.0",
	"title": "Team challenge button",
	"category": "clanspress-teams",
	"icon": "flag",
	"description": "Lets guests and team managers challenge this team when challenges are enabled.",
	"textdomain": "clanspress",
	"postTypes": [ "cp_team" ],
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js",
	"selectors": {
		"root": ".wp-block-clanspress-team-challenge-button",
		"color": {
			"text": ".wp-block-clanspress-team-challenge-button .wp-block-button__link, .wp-block-clanspress-team-challenge-button button",
			"background": ".wp-block-clanspress-team-challenge-button .wp-block-button__link, .wp-block-clanspress-team-challenge-button button"
		},
		"typography": ".wp-block-clanspress-team-challenge-button .wp-block-button__link",
		"border": ".wp-block-clanspress-team-challenge-button"
	}
}
