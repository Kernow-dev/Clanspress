{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/team-members-count",
	"version": "1.0.0",
	"title": "Team members count",
	"category": "clanspress-teams",
	"icon": "groups",
	"description": "Displays the number of roster members (excluding banned).",
	"textdomain": "clanspress",
	"postTypes": [
		"cp_team"
	],
	"usesContext": [
		"postId",
		"postType"
	],
	"attributes": {
		"label": {
			"type": "string",
			"default": ""
		},
		"prefix": {
			"type": "string",
			"default": ""
		},
		"postfix": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true,
			"__experimentalDefaultControls": {
				"blockGap": true
			}
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false,
		"layout": {
			"allowSwitching": false,
			"allowInheriting": false,
			"default": {
				"type": "flex",
				"flexWrap": "wrap"
			}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanspress-team-members-count",
		"color": ".wp-block-clanspress-team-members-count",
		"typography": ".wp-block-clanspress-team-members-count",
		"border": ".wp-block-clanspress-team-members-count"
	}
}
