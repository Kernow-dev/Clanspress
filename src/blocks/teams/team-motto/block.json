{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/team-motto",
	"version": "1.0.0",
	"title": "Team motto",
	"category": "clanspress-teams",
	"icon": "format-quote",
	"description": "Displays the team motto.",
	"textdomain": "clanspress",
	"postTypes": [ "cp_team" ],
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false,
		"typography": {
			"fontSize": true,
			"fontStyle": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanspress-team-motto",
		"color": {
			"text": ".wp-block-clanspress-team-motto .clanspress-team-motto__text",
			"background": ".wp-block-clanspress-team-motto"
		},
		"typography": ".wp-block-clanspress-team-motto .clanspress-team-motto__text",
		"border": ".wp-block-clanspress-team-motto"
	}
}
