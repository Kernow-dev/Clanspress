{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/team-code",
	"version": "1.0.0",
	"title": "Team code",
	"category": "clanspress-teams",
	"icon": "tag",
	"description": "Displays the short team code.",
	"textdomain": "clanspress",
	"postTypes": [ "cp_team" ],
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanspress-team-code",
		"color": {
			"text": ".wp-block-clanspress-team-code .clanspress-team-code__value",
			"background": ".wp-block-clanspress-team-code"
		},
		"typography": ".wp-block-clanspress-team-code .clanspress-team-code__value",
		"border": ".wp-block-clanspress-team-code"
	}
}
