{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/match-list",
	"version": "1.0.0",
	"title": "Match list",
	"category": "clanspress-matches",
	"icon": "list-view",
	"description": "List published matches with optional filters.",
	"textdomain": "clanspress",
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true,
			"link": true
		},
		"html": false,
		"align": true
	},
	"attributes": {
		"teamId": {
			"type": "number",
			"default": 0
		},
		"limit": {
			"type": "number",
			"default": 0
		},
		"statusFilter": {
			"type": "string",
			"default": ""
		},
		"order": {
			"type": "string",
			"default": "asc"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanspress-match-list",
		"color": {
			"text": ".wp-block-clanspress-match-list .clanspress-match-list, .wp-block-clanspress-match-list .clanspress-match-list__link",
			"background": ".wp-block-clanspress-match-list",
			"link": ".wp-block-clanspress-match-list .clanspress-match-list__link"
		},
		"typography": ".wp-block-clanspress-match-list .clanspress-match-list",
		"border": ".wp-block-clanspress-match-list"
	}
}
