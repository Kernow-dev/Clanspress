{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/player-settings-link",
	"version": "1.0.0",
	"title": "Player settings link",
	"category": "clanspress-players",
	"icon": "admin-settings",
	"description": "Link to player account settings. Only shown when the viewer is the profile owner.",
	"textdomain": "clanspress",
	"usesContext": [
		"postId",
		"postType",
		"clanspress/playerId"
	],
	"attributes": {
		"label": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false,
		"align": true,
		"typography": {
			"fontSize": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanspress-player-settings-link",
		"color": {
			"text": ".wp-block-clanspress-player-settings-link .wp-block-button__link",
			"background": ".wp-block-clanspress-player-settings-link .wp-block-button__link"
		},
		"typography": ".wp-block-clanspress-player-settings-link .wp-block-button__link",
		"border": ".wp-block-clanspress-player-settings-link"
	}
}
