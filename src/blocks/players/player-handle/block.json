{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/player-handle",
	"version": "1.0.0",
	"title": "Player @ handle",
	"category": "clanspress-players",
	"icon": "nametag",
	"description": "Displays the player’s @ handle (WordPress nicename) on profiles and in player loops — the taggable username form.",
	"textdomain": "clanspress",
	"keywords": [
		"@",
		"handle",
		"nicename",
		"username",
		"mention",
		"tag",
		"profile"
	],
	"usesContext": [ "postId", "postType", "clanspress/playerId" ],
	"attributes": {
		"textAlign": {
			"type": "string"
		}
	},
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false,
		"align": true,
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextDecoration": true,
			"__experimentalTextTransform": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanspress-player-handle",
		"color": {
			"text": ".wp-block-clanspress-player-handle .clanspress-player-handle__text",
			"background": ".wp-block-clanspress-player-handle"
		},
		"typography": ".wp-block-clanspress-player-handle .clanspress-player-handle__text",
		"border": ".wp-block-clanspress-player-handle"
	}
}
