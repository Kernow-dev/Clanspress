{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/user-nav",
	"version": "1.0.0",
	"title": "User Navigation",
	"category": "clanspress",
	"icon": "admin-users",
	"description": "Displays login/register links for guests, or user avatar with dropdown menu for logged-in users.",
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true,
			"link": true
		},
		"html": false,
		"align": false,
		"className": true,
		"interactivity": true
	},
	"attributes": {
		"avatarSize": {
			"type": "number",
			"default": 32
		},
		"showUsername": {
			"type": "boolean",
			"default": false
		}
	},
	"textdomain": "clanspress",
	"editorScript": "file:./index.js",
	"viewScriptModule": "file:./view.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"selectors": {
		"root": ".wp-block-clanspress-user-nav",
		"color": {
			"text": ".wp-block-clanspress-user-nav .clanspress-user-nav__link",
			"background": ".wp-block-clanspress-user-nav",
			"link": ".wp-block-clanspress-user-nav .clanspress-user-nav__link"
		},
		"typography": ".wp-block-clanspress-user-nav .clanspress-user-nav__link",
		"border": ".wp-block-clanspress-user-nav"
	}
}
