{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "clanspress/player-avatar",
	"version": "1.0.0",
	"title": "Player Avatar",
	"category": "clanspress-players",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {},
	"usesContext": [ "clanspress/playerId" ],
	"attributes": {
		"allowFrontEndMediaEdit": {
			"type": "boolean",
			"default": false
		},
		"isLink": {
			"type": "boolean",
			"default": false
		},
		"linkTarget": {
			"type": "string",
			"default": "_self"
		},
		"rel": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"color": {
			"text": true,
			"background": true
		},
		"html": false,
		"interactivity": true
	},
	"textdomain": "clanspress",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js",
	"selectors": {
		"root": ".wp-block-clanspress-player-avatar",
		"color": {
			"background": ".wp-block-clanspress-player-avatar"
		},
		"border": ".wp-block-clanspress-player-avatar .clanspress-player-avatar"
	}
}
